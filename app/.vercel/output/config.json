{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/about/administration/?(?:/__data.json)?$",
			"dest": "/about/administration"
		},
		{
			"src": "^/about/faculty/?(?:/__data.json)?$",
			"dest": "/about/faculty"
		},
		{
			"src": "^/about/history/?(?:/__data.json)?$",
			"dest": "/about/history"
		},
		{
			"src": "^/about/mission-vision/?(?:/__data.json)?$",
			"dest": "/about/mission-vision"
		},
		{
			"src": "^/about/overview/?(?:/__data.json)?$",
			"dest": "/about/overview"
		},
		{
			"src": "^/academics/11th/?(?:/__data.json)?$",
			"dest": "/academics/11th"
		},
		{
			"src": "^/academics/12th/?(?:/__data.json)?$",
			"dest": "/academics/12th"
		},
		{
			"src": "^/academics/bs/?(?:/__data.json)?$",
			"dest": "/academics/bs"
		},
		{
			"src": "^/academics/programs/?(?:/__data.json)?$",
			"dest": "/academics/programs"
		},
		{
			"src": "^/academics/syllabus/?(?:/__data.json)?$",
			"dest": "/academics/syllabus"
		},
		{
			"src": "^/admin/?(?:/__data.json)?$",
			"dest": "/admin"
		},
		{
			"src": "^/admin/login/?(?:/__data.json)?$",
			"dest": "/admin/login"
		},
		{
			"src": "^/admin/logout/?(?:/__data.json)?$",
			"dest": "/admin/logout"
		},
		{
			"src": "^/admissions/eligibility/?(?:/__data.json)?$",
			"dest": "/admissions/eligibility"
		},
		{
			"src": "^/admissions/fee-structure/?(?:/__data.json)?$",
			"dest": "/admissions/fee-structure"
		},
		{
			"src": "^/admissions/forms/?(?:/__data.json)?$",
			"dest": "/admissions/forms"
		},
		{
			"src": "^/admissions/how-to-apply/?(?:/__data.json)?$",
			"dest": "/admissions/how-to-apply"
		},
		{
			"src": "^/admissions/scholarships/?(?:/__data.json)?$",
			"dest": "/admissions/scholarships"
		},
		{
			"src": "^/api/announcements/?(?:/__data.json)?$",
			"dest": "/api/announcements"
		},
		{
			"src": "^/api/events/?(?:/__data.json)?$",
			"dest": "/api/events"
		},
		{
			"src": "^/api/init-db/?(?:/__data.json)?$",
			"dest": "/api/init-db"
		},
		{
			"src": "^/api/quick-links/?(?:/__data.json)?$",
			"dest": "/api/quick-links"
		},
		{
			"src": "^/api/results/?(?:/__data.json)?$",
			"dest": "/api/results"
		},
		{
			"src": "^/contact/?(?:/__data.json)?$",
			"dest": "/contact"
		},
		{
			"src": "^/departments/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/departments/[id]"
		},
		{
			"src": "^/news/announcements/?(?:/__data.json)?$",
			"dest": "/news/announcements"
		},
		{
			"src": "^/news/events/?(?:/__data.json)?$",
			"dest": "/news/events"
		},
		{
			"src": "^/news/gallery/?(?:/__data.json)?$",
			"dest": "/news/gallery"
		},
		{
			"src": "^/news/results/?(?:/__data.json)?$",
			"dest": "/news/results"
		},
		{
			"src": "^/resources/?(?:/__data.json)?$",
			"dest": "/resources"
		},
		{
			"src": "^/student-portal/?(?:/__data.json)?$",
			"dest": "/student-portal"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}